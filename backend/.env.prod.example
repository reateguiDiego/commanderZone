# Production template. Copy to real environment variables or an untracked .env.prod.
# Do not commit real secrets.

APP_ENV=prod
APP_DEBUG=0
APP_SECRET=change-me
APP_SHARE_DIR=var/share
DEFAULT_URI=https://api.commanderzone.com

DATABASE_URL="postgresql://user:password@host:5432/commanderzone?serverVersion=16&charset=utf8"

JWT_SECRET_KEY=change-this-production-jwt-secret
JWT_PUBLIC_KEY=change-this-production-jwt-secret
JWT_PASSPHRASE=

MERCURE_URL=https://api.commanderzone.com/.well-known/mercure
MERCURE_PUBLIC_URL=https://api.commanderzone.com/.well-known/mercure
MERCURE_JWT_SECRET=change-this-production-mercure-secret

SCRYFALL_USER_AGENT="CommanderZone/1.0 contact@example.com"
SCRYFALL_SYNC_MEMORY_LIMIT=1024M

CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$|^https://(www\.)?commanderzone\.com$'
