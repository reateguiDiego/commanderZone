{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration development",
    "start:local": "ng serve --configuration development",
    "build": "npm run write:seo-prerender-routes && npm run generate:sitemap && ng build",
    "build:local": "ng build --configuration development",
    "build:prod": "npm run write:seo-prerender-routes && npm run generate:sitemap && ng build --configuration production",
    "build:prerender": "npm run build:prod",
    "watch": "ng build --watch --configuration development",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "validate:canonical": "node scripts/validate-canonical-redirects.mjs",
    "validate:indexation": "node scripts/validate-indexation-controls.mjs",
    "validate:seo-final": "node scripts/validate-seo-final-architecture.mjs",
    "validate:seo-i18n": "node scripts/validate-seo-i18n-boundaries.mjs",
    "validate:legal-pages": "node scripts/validate-legal-pages.mjs",
    "validate:public-chrome": "node scripts/validate-public-chrome-localization.mjs",
    "validate:robots": "node scripts/validate-robots.mjs",
    "validate:seo-assets": "npm run validate:sitemap && npm run validate:canonical && npm run validate:seo-final && npm run validate:legal-pages && npm run validate:public-chrome && node scripts/validate-public-seo-assets.mjs && npm run validate:seo-links && npm run validate:seo-images && npm run validate:seo-performance && npm run validate:robots && npm run validate:indexation",
    "validate:seo-images": "node scripts/validate-seo-images.mjs",
    "validate:seo-links": "node scripts/validate-seo-crawlable-links.mjs",
    "validate:seo-performance": "node scripts/validate-seo-performance.mjs",
    "validate:sitemap": "node scripts/validate-sitemap.mjs",
    "write:seo-prerender-routes": "node scripts/write-seo-prerender-routes.mjs",
    "test": "ng test",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/common": "21.2.10",
    "@angular/compiler": "21.2.10",
    "@angular/core": "21.2.10",
    "@angular/forms": "21.2.10",
    "@angular/platform-browser": "21.2.10",
    "@angular/platform-server": "21.2.10",
    "@angular/router": "21.2.10",
    "@angular/ssr": "21.2.10",
    "@ngx-translate/core": "^17.0.0",
    "gsap": "^3.15.0",
    "lucide-angular": "^1.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.8",
    "@angular/cli": "^21.2.8",
    "@angular/compiler-cli": "21.2.10",
    "@playwright/test": "^1.59.1",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
